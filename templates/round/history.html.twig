{% extends 'base.html.twig' %}

{% block title %}Storico round — TwentyChoices{% endblock %}

{% block body %}
<div class="page-header">
    <div>
        <div class="eyebrow">Trasparenza pubblica</div>
        <h1>Storico round</h1>
        <p>I round conclusi espongono percorso vincente e nonce. Chiunque può ricostruire il commitment SHA-256 pubblicato prima delle giocate.</p>
    </div>
</div>

<div class="table-wrap">
    <table>
        <thead>
        <tr>
            <th>Round</th>
            <th>Stato</th>
            <th>Apertura</th>
            <th>Montepremio</th>
            <th>Vincitore</th>
            <th>Verifica</th>
        </tr>
        </thead>
        <tbody>
        {% for item in rows %}
            {% set round = item.round %}
            {% set verification = item.verification %}
            <tr>
                <td><a href="{{ path('app_round_show', {publicCode: round.publicCode}) }}"><code>{{ round.publicCode }}</code></a></td>
                <td><span class="badge {{ round.status == 'ACTIVE' ? 'badge-success' : 'badge-muted' }}">{{ round.status }}</span></td>
                <td>{{ round.startedAt ? round.startedAt|date('d/m/Y H:i:s') ~ ' UTC' : '—' }}</td>
                <td>{{ round.currentJackpotFormatted }}</td>
                <td><code>{{ round.winnerPlayPublicCode ?: '—' }}</code></td>
                <td>
                    {% if verification.available %}
                        <span class="badge {{ verification.commitmentMatches ? 'badge-success' : 'badge-error' }}">{{ verification.commitmentMatches ? 'VALIDO' : 'ERRORE' }}</span>
                    {% else %}
                        <span class="badge badge-muted">IN ATTESA</span>
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr><td colspan="6">Nessun round disponibile.</td></tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
