<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}TwentyChoices{% endblock %}</title>
    <style>
        :root {
            color-scheme: dark;
            font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            --bg: #11141b;
            --panel: #1a1f2a;
            --panel-2: #222936;
            --border: #343a49;
            --text: #f4f6fb;
            --muted: #aeb8ca;
            --accent: #8dd5ff;
            --success: #7fe0a2;
            --danger: #ff9a9a;
            --warning: #ffd47d;
        }
        * { box-sizing: border-box; }
        body { margin: 0; min-height: 100vh; background: var(--bg); color: var(--text); }
        a { color: var(--accent); }
        .topbar { border-bottom: 1px solid var(--border); background: rgba(17, 20, 27, .96); }
        .topbar-inner { max-width: 1180px; margin: 0 auto; padding: 15px 24px; display: flex; gap: 22px; align-items: center; }
        .brand { color: var(--text); font-weight: 800; text-decoration: none; letter-spacing: -.02em; }
        .nav-link { color: var(--muted); text-decoration: none; font-size: .94rem; }
        .nav-link:hover { color: var(--text); }
        main { max-width: 1180px; margin: 0 auto; padding: 48px 24px 72px; }
        .panel { padding: 30px; border: 1px solid var(--border); border-radius: 18px; background: var(--panel); }
        .eyebrow { letter-spacing: .12em; text-transform: uppercase; color: #9ba7bd; font-size: .78rem; }
        h1 { margin: 10px 0 14px; font-size: clamp(2.1rem, 6vw, 4.5rem); line-height: .98; }
        h2 { margin: 0; }
        p { color: #c4ccda; line-height: 1.65; }
        .amount { margin-top: 32px; font-size: clamp(2rem, 5vw, 4rem); font-weight: 800; }
        .notice { margin-top: 24px; padding: 14px 16px; border-radius: 10px; background: #252c3a; }
        .page-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 24px; margin-bottom: 24px; }
        .page-header h1 { font-size: clamp(2rem, 4vw, 3.2rem); margin-top: 0; }
        .button { display: inline-flex; align-items: center; justify-content: center; min-height: 40px; padding: 9px 15px; border: 1px solid #536177; border-radius: 9px; background: #2b3444; color: var(--text); text-decoration: none; cursor: pointer; font: inherit; }
        .button:hover { background: #354055; }
        .button-primary { background: #1674a8; border-color: #258fc9; }
        .button-danger { background: #542c32; border-color: #83414c; }
        .button-quiet { background: transparent; }
        .button[disabled] { opacity: .45; cursor: not-allowed; }
        .actions { display: flex; flex-wrap: wrap; gap: 8px; }
        .summary { display: flex; gap: 18px; flex-wrap: wrap; margin: 0 0 24px; }
        .summary-item { min-width: 180px; padding: 16px 18px; background: var(--panel); border: 1px solid var(--border); border-radius: 12px; }
        .summary-value { display: block; font-size: 1.55rem; font-weight: 800; }
        .summary-label { color: var(--muted); font-size: .88rem; }
        .table-wrap { overflow-x: auto; border: 1px solid var(--border); border-radius: 14px; }
        table { width: 100%; border-collapse: collapse; background: var(--panel); }
        th, td { padding: 13px 14px; text-align: left; vertical-align: middle; border-bottom: 1px solid var(--border); }
        th { color: var(--muted); font-size: .78rem; letter-spacing: .06em; text-transform: uppercase; background: var(--panel-2); }
        tr:last-child td { border-bottom: 0; }
        code { color: #bfe7ff; }
        .badge { display: inline-flex; align-items: center; padding: 4px 8px; border-radius: 999px; font-size: .78rem; background: #313a49; }
        .badge-success { color: #b8ffd0; background: #234331; }
        .badge-muted { color: #cad1df; background: #333946; }
        .badge-system { color: #ffe5a3; background: #4c4024; }
        .flash { margin-bottom: 18px; padding: 13px 15px; border-radius: 10px; border: 1px solid var(--border); }
        .flash-success { background: #1f3d2b; color: #b8ffd0; }
        .flash-error { background: #4d2930; color: #ffd1d1; }
        .form-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18px; }
        .field { display: grid; gap: 7px; }
        .field-full { grid-column: 1 / -1; }
        label { color: #dde3ee; font-weight: 650; }
        input { width: 100%; min-height: 43px; padding: 9px 11px; color: var(--text); background: #111722; border: 1px solid #465064; border-radius: 9px; font: inherit; }
        input:focus { outline: 2px solid #2b8cbf; outline-offset: 1px; }
        input[readonly] { color: var(--muted); background: #242a35; }
        .help { color: var(--muted); font-size: .84rem; line-height: 1.45; }
        .error-box { margin-bottom: 18px; padding: 13px 15px; border: 1px solid #874550; border-radius: 10px; background: #4d2930; color: #ffd1d1; }
        .form-footer { display: flex; gap: 10px; margin-top: 24px; }
        .inline-form { display: inline; }
        @media (max-width: 760px) {
            .topbar-inner, .page-header, .form-footer { align-items: stretch; }
            .page-header { flex-direction: column; }
            .form-grid { grid-template-columns: 1fr; }
            .field-full { grid-column: auto; }
            main { padding-top: 30px; }
        }
    </style>
</head>
<body>
<header class="topbar">
    <nav class="topbar-inner" aria-label="Navigazione principale">
        <a class="brand" href="{{ path('app_home') }}">TwentyChoices</a>
        <a class="nav-link" href="{{ path('admin_choice_pair_index') }}">Catalogo scelte</a>
    </nav>
</header>
<main>
    {% for message in app.flashes('success') %}
        <div class="flash flash-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="flash flash-error">{{ message }}</div>
    {% endfor %}
    {% block body %}{% endblock %}
</main>
</body>
</html>
