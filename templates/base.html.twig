<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}TwentyChoices{% endblock %}</title>
    <link rel="stylesheet" href="{{ asset('app.css') }}">
</head>
<body>
<a class="skip-link" href="#main-content">Salta al contenuto principale</a>
<header class="topbar">
    <nav class="topbar-inner" aria-label="Navigazione principale">
        <a class="brand" href="{{ path('app_home') }}">TwentyChoices</a>
        <a class="nav-link" href="{{ path('app_round_history') }}">Storico pubblico</a>
        <span class="nav-spacer"></span>
        {% set admin_session = app.session.get('twenty_admin_identity') %}
        {% if admin_session %}
            <a class="nav-link" href="{{ path('admin_dashboard') }}">Amministrazione</a>
            {% if admin_session.role in ['SUPER_ADMIN', 'OPERATOR'] %}
                <a class="nav-link" href="{{ path('admin_choice_pair_index') }}">Catalogo</a>
                <a class="nav-link" href="{{ path('admin_round_index') }}">Round</a>
            {% endif %}
            <a class="nav-link" href="{{ path('admin_simulation_index') }}">Simulazioni</a>
            {% if admin_session.role in ['SUPER_ADMIN', 'AUDITOR'] %}<a class="nav-link" href="{{ path('admin_diagnostics_index') }}">Diagnostica</a>{% endif %}
            {% if admin_session.role == 'SUPER_ADMIN' %}<a class="nav-link" href="{{ path('admin_user_index') }}">Utenti</a>{% endif %}
            <span class="admin-session"><span>{{ admin_session.username }} · {{ admin_session.role }}</span>
                <form class="logout-form" method="post" action="{{ path('admin_logout') }}"><input type="hidden" name="_token" value="{{ csrf_token('admin_logout') }}"><button class="button button-quiet" type="submit">Esci</button></form>
            </span>
        {% else %}
            <a class="nav-link" href="{{ path('admin_login') }}">Accesso admin</a>
        {% endif %}
    </nav>
</header>
<main id="main-content" tabindex="-1">
    {% for message in app.flashes('success') %}<div class="flash flash-success" role="status">{{ message }}</div>{% endfor %}
    {% for message in app.flashes('error') %}<div class="flash flash-error" role="alert">{{ message }}</div>{% endfor %}
    {% block body %}{% endblock %}
</main>
</body>
</html>
